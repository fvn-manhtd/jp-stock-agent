# JPStock Agent Configuration
# Copy this file to .env and fill in your values.

# ── Data Sources ──────────────────────────────────────────────
JPSTOCK_DEFAULT_SOURCE=yfinance          # yfinance or jquants

# J-Quants (official JPX data) – pick ONE auth method:
# JQUANTS_API_KEY=                       # v2 API key (recommended)
# JQUANTS_API_EMAIL=                     # v1 email
# JQUANTS_API_PASSWORD=                  # v1 password
# JQUANTS_REFRESH_TOKEN=                 # v1 refresh token

# vnstock (Vietnamese markets) – optional, raises rate limit 20→60 req/min:
# VNSTOCK_API_KEY=

# ── MCP Server ────────────────────────────────────────────────
JPSTOCK_MCP_TRANSPORT=stdio              # stdio, sse, or http
JPSTOCK_MCP_HOST=0.0.0.0
JPSTOCK_MCP_PORT=8000

# ── Authentication ────────────────────────────────────────────
JPSTOCK_AUTH_ENABLED=false               # Set true for commercial deployment
# JPSTOCK_AUTH_KEY_FILE=                 # Custom key store path (default ~/.jpstock/keys.json)
# JPSTOCK_MASTER_KEY=                    # Admin key – bypasses auth + rate limits

# ── Rate Limiting ─────────────────────────────────────────────
JPSTOCK_RATE_LIMIT_ENABLED=true          # Works even when auth is off
JPSTOCK_BURST_PER_MINUTE=30              # Max calls per key per minute
